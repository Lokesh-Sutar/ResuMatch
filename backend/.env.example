# Google Gemini API Configuration
#Multiple keys for round-robin + failover.
# You can use either numbered keys...
GEMINI_API_KEY_1=your_gemini_api_key_1_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here
GEMINI_API_KEY_3=your_gemini_api_key_3_here

# ...or a comma-separated list.
# GEMINI_API_KEYS=key1,key2,key3

# Optional: Choose AI provider (gemini or fallback)
AI_PROVIDER=gemini

# Optional: Gemini model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
